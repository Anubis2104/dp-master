# ============================================================
# HƯỚNG DẪN: Copy file này thành .env rồi điền các giá trị
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------------
# BẮT BUỘC: Secret key dùng để mã hóa session và CSRF token
# Tạo key ngẫu nhiên mạnh bằng lệnh:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------
SECRET_KEY=THAY_BANG_KEY_NGAU_NHIEN_CUA_BAN

# ----------------------------------------------------------------
# Database URI
# - SQLite (mặc định, phù hợp dự án nhỏ):
#     DATABASE_URI=sqlite:////app/instance/dp_master.db
# - PostgreSQL (khuyến nghị cho production nhiều user):
#     DATABASE_URI=postgresql://user:password@host:5432/dbname
# ----------------------------------------------------------------
DATABASE_URI=sqlite:////app/instance/dp_master.db

# ----------------------------------------------------------------
# Chế độ debug (KHÔNG bao giờ đặt thành 1 trong production)
# - 0 = production (mặc định)
# - 1 = development (bật auto-reload, hiện lỗi chi tiết)
# ----------------------------------------------------------------
FLASK_DEBUG=0

# ----------------------------------------------------------------
# Port server lắng nghe (mặc định 5000)
# ----------------------------------------------------------------
PORT=5000

# ----------------------------------------------------------------
# Log level: debug | info | warning | error | critical
# ----------------------------------------------------------------
LOG_LEVEL=info
